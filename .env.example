# ─────────────────────────────────────────────────────────────────────────────
# airlock — .env.example   (copy to `.env`, which is gitignored)
#
# The CLI auto-loads `.env` from the current directory at startup. Values already
# in your shell environment take precedence over the file.
# ─────────────────────────────────────────────────────────────────────────────

# ── Cloudflare DURABLE tunnel — a PERSISTENT public URL (not the ephemeral one) ─
# This is a Tunnel CONNECTOR TOKEN — NOT a Cloudflare API key / Global API Token.
# Get it:  Cloudflare dashboard → Zero Trust → Networks → Tunnels → Create a tunnel
#   → choose "Cloudflared" → copy the token (the long "eyJ…" string shown after
#   `--token` in the install command). Then on that tunnel add a Public Hostname,
#   e.g.  agent.yourdomain.com  →  Service  http://localhost:3000
# Run:  airlock up --docker --durable --hostname agent.yourdomain.com
AIRLOCK_CF_TUNNEL_TOKEN=

# ── Model endpoint (for real tool-calling / production answers) ──────────────────
# Any OpenAI-compatible endpoint. On an 8GB box a strong local tool-caller is tight,
# so a hosted key is the most reliable for real tool-chaining. Referenced from
# worker.yaml  models.<name>.env_key  (default OPENAI_API_KEY).
OPENAI_API_KEY=
# Optional base override for a self-hosted/proxy endpoint (e.g. http://host:11434/v1).
OPENAI_API_BASE=

# ── Webhook trigger signing (epic 11) ───────────────────────────────────────────
HOOK_SECRET=

# ── Optional ────────────────────────────────────────────────────────────────────
# AIRLOCK_PROFILE=external      # default worker.yaml variant to run
# AIRLOCK_MAX_CONCURRENCY=4
# PORT=3000
