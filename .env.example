# ─────────────────────────────────────────────────────────────────────────────
# airlock (deploy · host + sell)  —  .env.example
#
# Template. Copy to `.env` (gitignored) and fill in:  cp .env.example .env
# These are the PUBLISHER's secrets. Non-secret config (sell-side wallet/price,
# harness binding) lives in .airlock/config.toml, NOT here.
# ─────────────────────────────────────────────────────────────────────────────

# ── Durable public URL — bring-your-own Cloudflare named tunnel ──────────────
# Needed ONLY for `airlock up --durable`. Create a tunnel + Public Hostname in
# YOUR OWN Cloudflare Zero Trust dashboard (Networks → Tunnels) and paste its
# connector token here. The default `airlock up` (ephemeral quick tunnel) needs
# nothing. Set the matching hostname in .airlock/config.toml → [tunnel].hostname.
# Guide: docs/durable-hosting.md
AIRLOCK_CF_TUNNEL_TOKEN=

# ── Your model (inference endpoint) ──────────────────────────────────────────
# Consumed by your agent/harness. A LOCAL model (gguf/vLLM) needs NEITHER of
# these — only set them to point at a remote OpenAI-compatible endpoint.
OPENAI_API_BASE=
OPENAI_API_KEY=

# ── Deploy to a cloud you own (optional) ─────────────────────────────────────
# Fly is bring-your-own + EXPERIMENTAL. Normally you just run `fly auth login`
# once; set a token only for non-interactive / CI deploys.
# FLY_API_TOKEN=

# ── Dashboard backend (optional) ─────────────────────────────────────────────
# Only if you use `airlock login` / `airlock sync` against a dashboard backend.
# `airlock login` normally writes ~/.airlock/auth.json; these override it.
# AIRLOCK_DEPLOY_BACKEND=http://localhost:8787
# AIRLOCK_TOKEN=

# ── Agent-to-agent BUY tool (optional · uses the bundled airlock-crypto) ──────
# Set ONLY if your deployed agent should PAY other agents via the
# `airlock-agent[crypto]` extra. These ARE the airlock-crypto wallet creds —
# see ../airlock-crypto/.env.example for the canonical wallet setup. The spend
# caps bound an autonomous loop so it can't drain the wallet.
# AIRLOCK_WALLET_KEY=0xYOUR_PRIVATE_KEY
# AIRLOCK_WALLET_NETWORK=base-sepolia
# AIRLOCK_SPEND_PER_CALL=0.05
# AIRLOCK_SPEND_PER_PERIOD=1.00

# ── Optional runtime knobs ───────────────────────────────────────────────────
# PORT=3000
# AIRLOCK_PYTHON=python3

# ── ONLY if you self-host the dashboard backend (packages/server) ────────────
# Operator role — NOT needed to publish an agent. A GitHub OAuth app's creds +
# the server's own settings.
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# PUBLIC_BASE_URL=http://localhost:8787
# DB_PATH=./airlock.db
