{
  "name": "@airlockhq/server",
  "version": "0.2.0",
  "private": true,
  "description": "airlock backend — GitHub OAuth (web + device flow), dashboard, SQLite-backed projects/inspect store. Runs on :8787 in dev.",
  "type": "module",
  "license": "Apache-2.0",
  "main": "./dist/server.js",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx watch src/server.ts",
    "start": "node --import=tsx src/server.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "better-sqlite3": "^12.0.0",
    "cookie-parser": "^1.4.7",
    "express": "^5.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
