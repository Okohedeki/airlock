{
  "name": "@airlockhq/payment-fly-node",
  "version": "0.0.0",
  "private": true,
  "description": "x402 Payment Middleware for Node.js / Express on the Fly Recipe — wraps an async handler, enforces payment per call.",
  "type": "module",
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@airlockhq/payment-core": "workspace:*",
    "@x402/core": "^2.13.0"
  },
  "peerDependencies": {
    "express": "^4.18.0 || ^5.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "express": "^5.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
