{
  "name": "@airlockhq/cli",
  "version": "0.1.0",
  "private": true,
  "description": "airlock CLI — local project setup, config validation, and status. v1.x scope is local file ops; deploy/tunnel/auth land in v1.1+.",
  "type": "module",
  "license": "Apache-2.0",
  "bin": {
    "airlock": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && npm run copy-assets",
    "copy-assets": "mkdir -p dist/worker-schema && cp src/worker-schema/*.json dist/worker-schema/",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "cloudflared": "^0.7.1",
    "commander": "^14.0.0",
    "smol-toml": "^1.3.0",
    "yaml": "^2.9.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
